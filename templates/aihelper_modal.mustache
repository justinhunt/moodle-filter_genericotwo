<div class="filter_genericotwo_aihelper_modal">
    <p class="text-muted small mb-3">{{#str}} aihelper_modal_instruction, filter_genericotwo {{/str}}</p>
    <div class="form-group">
        <label for="filter_genericotwo_aihelper_prompt">{{#str}} aihelper_prompt_label, filter_genericotwo {{/str}}</label>
        <textarea id="filter_genericotwo_aihelper_prompt" class="form-control" rows="4" placeholder="{{#placeholder}}{{placeholder}}{{/placeholder}}{{^placeholder}}{{#str}} aihelper_prompt_placeholder, filter_genericotwo {{/str}}{{/placeholder}}"></textarea>
    </div>
    <div class="filter_genericotwo_aihelper_response_container d-none">
        <label>{{#str}} aihelper_response_label, filter_genericotwo {{/str}}</label>
        <pre id="filter_genericotwo_aihelper_response" class="bg-light p-2 border" style="max-height: 300px; overflow-y: auto;"></pre>
    </div>
    <div class="filter_genericotwo_aihelper_loading d-none text-center p-3">
        <div class="spinner-border text-primary" role="status">
            <span class="sr-only">{{#str}} loading, core {{/str}}</span>
        </div>
        <p class="mt-2">{{#str}} aihelper_generating, filter_genericotwo {{/str}}</p>
    </div>
</div>
